{
  "configurations": [
    {
      "name": "ESP32 Arduino",
      "includePath": [
        "${workspaceFolder}/**",
        "${userHome}/Documents/Arduino/libraries/**",
        "${userHome}/AppData/Local/Arduino15/packages/esp32/hardware/esp32/**",
        "${userHome}/AppData/Local/Arduino15/packages/esp32/tools/**"
      ],
      "defines": ["ARDUINO=10819", "ESP32", "ARDUINO_ARCH_ESP32"],
      "cStandard": "c17",
      "cppStandard": "c++17",
      "intelliSenseMode": "gcc-x64"
    }
  ],
  "version": 4
}
